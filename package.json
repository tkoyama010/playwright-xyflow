{
	"name": "playwright-xyflow",
	"version": "0.1.0",
	"description": "Playwright testing utilities for React Flow and Svelte Flow (xyflow)",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"format": "biome format --write .",
		"lint": "biome check .",
		"test": "playwright test",
		"prepare": "npm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tkoyama010/playwright-xyflow.git"
	},
	"keywords": [
		"playwright",
		"testing",
		"e2e",
		"react-flow",
		"svelte-flow",
		"xyflow"
	],
	"author": "",
	"license": "MIT",
	"peerDependencies": {
		"@playwright/test": "^1.40.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@playwright/test": "^1.50.0",
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0"
	}
}
